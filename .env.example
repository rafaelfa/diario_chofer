# ===========================================
# Diario do Motorista - Variaveis de Ambiente
# ===========================================
# Copie este ficheiro para .env.local e preencha os valores

# Banco de dados (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[SUA_SENHA]@db.[SEU_PROJETO].supabase.co:5432/postgres"

# Chave secreta para JWT (gere com: openssl rand -base64 32)
JWT_SECRET="[GERE_UMA_CHAVE_SECRETA_AQUI]"

# URL publica do site (para CORS)
NEXT_PUBLIC_APP_URL="https://[SEU-DOMINIO].vercel.app"
