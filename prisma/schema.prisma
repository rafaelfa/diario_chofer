// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// Dia de trabalho do motorista
model WorkDay {
  id            String    @id @default(cuid())
  date          DateTime?
  startTime     String?
  endTime       String?
  startCountry  String?
  endCountry    String?
  startKm       Int?
  endKm         Int?
  lastRest      String?
  amplitude     String?
  truckCheck    Boolean   @default(false)
  observations  String?
  matricula     String?   // Matrícula do caminhão (formato europeu: AA-00-BB)
  isPaused      Boolean   @default(false) // Indica se está pausado (outro motorista dirigindo)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relacionamento com eventos
  events        Event[]
  
  // Sessões de condução (para dupla de motoristas)
  drivingSessions DrivingSession[]

  @@index([matricula]) // Índice para busca por matrícula
  @@map("work_days")
}

// Eventos do dia (pausas, abastecimento, fronteiras, etc.)
model Event {
  id          String   @id @default(cuid())
  workDayId   String
  time        String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacionamento
  workDay     WorkDay  @relation(fields: [workDayId], references: [id], onDelete: Cascade)

  @@map("events")
}

// Sessões de condução (para dupla de motoristas)
model DrivingSession {
  id          String   @id @default(cuid())
  workDayId   String
  startTime   String           // Hora de início da sessão
  endTime     String?          // Hora de fim da sessão (null se em andamento)
  startKm     Int?             // KM no início da sessão
  endKm       Int?             // KM no fim da sessão
  status      String   @default("active") // active, paused, ended
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacionamento
  workDay     WorkDay  @relation(fields: [workDayId], references: [id], onDelete: Cascade)

  @@map("driving_sessions")
}

// Configurações do usuário
model Settings {
  id                    String   @id @default(cuid())
  maxDailyDrivingHours  Float    @default(9.0)
  maxWeeklyDrivingHours Float    @default(56.0)
  maxContinuousDriving  Float    @default(4.5)
  breakDuration         Int      @default(45)
  alertBeforeMinutes    Int      @default(30)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("settings")
}

// Usuário da aplicação (tabela separada do Supabase Auth)
model AppUser {
  id            String   @id @default(cuid())
  username      String   @unique
  passwordHash  String   @map("password_hash")
  name          String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("app_users")
}
